# Public Supabase project URL used by browser and server clients.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Public Supabase anonymous key used by browser and server SSR auth flows.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-only Supabase service role key for privileged backend operations.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# OpenAI API key used for draft generation.
OPENAI_API_KEY=your-openai-api-key

# Optional comma-separated domain allowlist for recipient policy checks.
ALLOWED_EMAIL_DOMAINS=example.com,company.com

# Token for authenticated planner trigger endpoint /api/planner/run (prod/non-dev).
PLANNER_RUN_TOKEN=replace-with-random-long-token

# Token for monitor tick endpoint /api/monitor/run (falls back to PLANNER_RUN_TOKEN in CI workflow if unset there).
MONITOR_RUN_TOKEN=replace-with-random-long-token

# Token for external event intake endpoint /api/events/intake (required outside development).
EVENTS_INGEST_TOKEN=replace-with-random-long-token

# Token for external event auto-caseify endpoint /api/events/auto-caseify (fallback to PLANNER_RUN_TOKEN when unset).
EVENTS_AUTOMATION_TOKEN=replace-with-random-long-token

# Stale threshold hours for monitor signal detection (fallback to PLANNER_STALE_HOURS).
MONITOR_STALE_HOURS=6

# Enable/disable monitor nudge posting to shared chat when signals are detected (1/0).
MONITOR_CHAT_NUDGE_ENABLED=1

# Cooldown seconds for @AI monitor recovery command to avoid duplicate burst runs.
MONITOR_RECOVERY_COOLDOWN_SECONDS=90

# Extra retry passes for failed workflow retries in monitor recovery (0..3).
MONITOR_RECOVERY_WORKFLOW_RETRY_PASSES=1

# Governance: risk score threshold to require two-person approval for execution.
GOVERNANCE_HIGH_RISK_THRESHOLD=70

# Governance: max successful google/send_email executions allowed in rolling 1 hour.
GOVERNANCE_HOURLY_SEND_EMAIL_LIMIT=10

# Monitor recovery: auto-create/update exception_cases for manual workflow failures (1/0).
MONITOR_RECOVERY_EXCEPTION_AUTO_CREATE=1

# Monitor recovery: due SLA hours for auto-created exception cases.
MONITOR_RECOVERY_EXCEPTION_SLA_HOURS=8

# Workflow orchestrator: auto-create exception case when workflow run fails (1/0).
WORKFLOW_FAILURE_EXCEPTION_AUTO_CREATE=1

# Workflow orchestrator: SLA hours for auto-created failed_workflow exception case.
WORKFLOW_FAILURE_EXCEPTION_SLA_HOURS=8

# Token for governance recommendations review endpoint /api/governance/recommendations/run (falls back to PLANNER_RUN_TOKEN if unset).
GOV_RECOMMENDATIONS_TOKEN=replace-with-random-long-token

# Token for workflow tick endpoint /api/workflows/tick (falls back to PLANNER_RUN_TOKEN if unset).
WORKFLOW_TICK_TOKEN=replace-with-random-long-token

# Token for incident auto-open endpoint /api/incidents/auto-open (falls back to GOV_RECOMMENDATIONS_TOKEN -> PLANNER_RUN_TOKEN).
INCIDENT_AUTOMATION_TOKEN=replace-with-random-long-token

# Enable/disable automatic incident opening from repeated failures (0/1).
INCIDENT_AUTO_OPEN_ENABLED=0

# Consecutive planner/review failure threshold for opening auto incident.
INCIDENT_AUTO_FAIL_THRESHOLD=3

# Number of ACTION_FAILED in lookback window to open auto incident.
INCIDENT_AUTO_ACTION_FAILED_THRESHOLD=5

# Lookback window (hours) for action failure burst detection.
INCIDENT_AUTO_LOOKBACK_HOURS=6


# Token for exception alert endpoint /api/operations/exceptions/alerts (fallback: INCIDENT_AUTOMATION_TOKEN -> GOV_RECOMMENDATIONS_TOKEN -> PLANNER_RUN_TOKEN).
EXCEPTION_ALERTS_TOKEN=replace-with-random-long-token

# Token for approval reminder endpoint /api/approvals/reminders (fallback: EXCEPTION_ALERTS_TOKEN -> INCIDENT_AUTOMATION_TOKEN -> GOV_RECOMMENDATIONS_TOKEN -> PLANNER_RUN_TOKEN).
APPROVAL_REMINDER_TOKEN=replace-with-random-long-token

# Token for chat confirmation maintenance endpoint /api/chat/confirmations/expire (fallback: APPROVAL_REMINDER_TOKEN -> EXCEPTION_ALERTS_TOKEN -> INCIDENT_AUTOMATION_TOKEN -> GOV_RECOMMENDATIONS_TOKEN -> PLANNER_RUN_TOKEN).
CHAT_CONFIRMATIONS_TOKEN=replace-with-random-long-token

# Optional token for server-to-server chat audit export endpoint access (`x-export-token` + `org_id` required).
CHAT_EXPORT_TOKEN=replace-with-random-long-token

# Optional token for server-to-server exception export endpoint access (`x-export-token` + `org_id` required).
EXCEPTION_EXPORT_TOKEN=replace-with-random-long-token

# Alert cooldown (minutes) for the same exception case notification.
EXCEPTION_ALERT_COOLDOWN_MINUTES=60

# Circuit breaker threshold for per-job consecutive failures (open circuit when reached).
OPS_JOB_CIRCUIT_BREAKER_THRESHOLD=3

# Pause window (minutes) while job circuit is open.
OPS_JOB_CIRCUIT_BREAKER_PAUSE_MINUTES=30

# Dry-run probe window (minutes) after pause expires and resume gate passes.
OPS_JOB_CIRCUIT_DRY_RUN_MINUTES=10

# Re-check interval (minutes) when resume gate is not met.
OPS_JOB_CIRCUIT_RECHECK_MINUTES=15

# Minimum recent success rate recovered/(recovered+exhausted) to auto-resume without manual clear.
OPS_JOB_CIRCUIT_MIN_SUCCESS_RATE=0.6

# Minimum sample size for success-rate gate.
OPS_JOB_CIRCUIT_MIN_SAMPLE_SIZE=5

# Escalation threshold hours for exception alerts (L1/L2/L3 => medium/high/critical).
EXCEPTION_ESCALATION_HOURS_L1=2
EXCEPTION_ESCALATION_HOURS_L2=8
EXCEPTION_ESCALATION_HOURS_L3=24

# Slack bot token used for intake and approval interactions.
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# Slack signing secret used to verify Slack request signatures.
SLACK_SIGNING_SECRET=your-slack-signing-secret

# Slack channel ID used for posting approval requests.
SLACK_APPROVAL_CHANNEL_ID=C0123456789

# Optional Slack channel ID for task intake events (fallback to approval channel).
SLACK_INTAKE_CHANNEL_ID=C0111111111

# Optional Slack channel ID for operations alerts (fallbacks: connector alert_channel_id -> approval channel).
SLACK_ALERTS_CHANNEL_ID=C0987654321

# Optional default org_id used only in env-only Slack mode when connector_accounts mapping is absent.
SLACK_DEFAULT_ORG_ID=00000000-0000-0000-0000-000000000000

# Enable ops Slack alerts when 1 (default disabled).
ENABLE_OPS_SLACK_ALERTS=0

# Consecutive failure threshold for ops alert trigger.
OPS_ALERT_CONSECUTIVE_FAIL_THRESHOLD=2

# Base URL used in Slack messages and interactive links.
APP_BASE_URL=http://localhost:3000

# Google OAuth client ID for Gmail connector authorization.
GOOGLE_CLIENT_ID=your-google-client-id

# Google OAuth client secret for Gmail connector authorization.
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Optional legacy fallback refresh token when DB connector is not configured.
GOOGLE_REFRESH_TOKEN=your-google-refresh-token

# Optional legacy fallback sender email when DB connector is not configured.
GOOGLE_SENDER_EMAIL=sender@example.com

# Deprecated fallback only when APP_BASE_URL is missing (prefer APP_BASE_URL).
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback

# Pending approval age threshold (hours) for exception queue highlighting.
EXCEPTION_PENDING_APPROVAL_HOURS=6

# Optional stale threshold (hours) for automated approval reminder job. Uses EXCEPTION_PENDING_APPROVAL_HOURS when unset.
APPROVAL_REMINDER_STALE_HOURS=6

# Cooldown minutes for sending repeated reminders to the same pending approval.
APPROVAL_REMINDER_COOLDOWN_MINUTES=120

# Maximum reminder targets processed per org per run.
APPROVAL_REMINDER_MAX_TARGETS=20

# Guard threshold for /api/approvals/reminders/auto (run reminders only when stale pending count >= this value).
APPROVAL_REMINDER_AUTO_MIN_STALE=3

# Per-user daily cap for mutating chat command executions (create/approval/execute).
CHAT_DAILY_EXECUTION_LIMIT=30

# Max age (seconds) for status-query TOP candidates used by quick actions; older candidates require fresh status query.
CHAT_STATUS_TOP_TTL_SECONDS=600

# Timeout (seconds) for a workflow step staying in running state before auto-failing it in tick.
WORKFLOW_STEP_TIMEOUT_SECONDS=900

# Maximum retry attempts per failed workflow step.
WORKFLOW_STEP_MAX_RETRIES=3
