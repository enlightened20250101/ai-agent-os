# Public Supabase project URL used by browser and server clients.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Public Supabase anonymous key used by browser and server SSR auth flows.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-only Supabase service role key for privileged backend operations.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# OpenAI API key used for draft generation.
OPENAI_API_KEY=your-openai-api-key

# Optional comma-separated domain allowlist for recipient policy checks.
ALLOWED_EMAIL_DOMAINS=example.com,company.com

# Slack bot token used for intake and approval interactions.
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# Slack signing secret used to verify Slack request signatures.
SLACK_SIGNING_SECRET=your-slack-signing-secret

# Slack channel ID used for posting approval requests.
SLACK_APPROVAL_CHANNEL_ID=C0123456789

# Base URL used in Slack messages and interactive links.
APP_BASE_URL=http://localhost:3000

# Google OAuth client ID for Gmail connector authorization.
GOOGLE_CLIENT_ID=your-google-client-id

# Google OAuth client secret for Gmail connector authorization.
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Redirect URI registered in Google OAuth settings.
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback
